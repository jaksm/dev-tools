{
  "name": "@jaksm/dev-tools",
  "version": "0.1.0",
  "description": "IDE-grade coding tools for AI agents — foundation tools, code intelligence, workflow automation. Use as an OpenClaw plugin or import tools directly into any agent framework.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./tools": {
      "types": "./dist/tools/index.d.ts",
      "import": "./dist/tools/index.js"
    },
    "./core": {
      "types": "./dist/core/index.d.ts",
      "import": "./dist/core/index.js"
    }
  },
  "openclaw": {
    "extensions": [
      "./dist/index.js"
    ]
  },
  "files": [
    "dist",
    "openclaw.plugin.json",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc",
    "watch": "tsc --watch",
    "clean": "rm -rf dist",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "ai-agent",
    "coding-tools",
    "openclaw",
    "code-intelligence",
    "tree-sitter",
    "lsp",
    "semantic-search",
    "developer-tools"
  ],
  "author": "Jakša Mališić <jaksa.malisic@gmail.com>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/jaksm/dev-tools.git"
  },
  "homepage": "https://github.com/jaksm/dev-tools#readme",
  "bugs": {
    "url": "https://github.com/jaksm/dev-tools/issues"
  },
  "dependencies": {
    "@huggingface/transformers": "^3.8.1",
    "@sinclair/typebox": "^0.34.30",
    "chokidar": "^5.0.0",
    "fast-glob": "^3.3.3",
    "hnswlib-node": "^3.0.0",
    "ignore": "^7.0.3",
    "tree-sitter-wasms": "^0.1.13",
    "vscode-jsonrpc": "^8.2.1",
    "vscode-languageserver-protocol": "^3.17.5",
    "web-tree-sitter": "^0.20.8"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "typescript": "^5.7.0",
    "vitest": "^4.0.18"
  },
  "engines": {
    "node": ">=20"
  }
}
